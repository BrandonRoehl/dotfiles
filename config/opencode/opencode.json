{
    "$schema": "https://opencode.ai/config.json",
    "enabled_providers": ["lmstudio", "amazon-bedrock", "github-copilot"],
    "provider": {
        "lmstudio": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "LM Studio (local)",
            "options": {
                "baseURL": "http://127.0.0.1:1234/v1"
            },
            "models": {
                "google/gemma-4-e4b": {
                    "name": "Gemma 4"
                },
                "openai/gpt-oss-20b": {
                    "name": "GPT-OSS 20B"
                },
                "deepseek/deepseek-r1-0528-qwen3-8b": {
                    "name": "DeepSeek R1 0528"
                }
            }
        },
        "amazon-bedrock": {
            "options": {
                "region": "us-east-1",
                "profile": "claude"
            }
        }
    }
}
